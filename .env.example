# Copy to .env and fill in. Never commit .env.

OPENAI_API_KEY=sk-your-key-here
SERPAPI_API_KEY=your-serpapi-key-here

# Fast, cost-effective default (override if you prefer)
OPENAI_MODEL=gpt-4o-mini

# After you deploy (Hugging Face Spaces, etc.), set this so the app and README can link to your live demo
PUBLIC_APP_URL=https://huggingface.co/spaces/YOUR_USERNAME/YOUR_SPACE_NAME

# Qdrant: default is embedded storage in ./qdrant_storage (no Docker). Optional overrides:
# QDRANT_PATH=C:\path\to\custom_storage
# QDRANT_URL=https://xxxx.cloud.qdrant.io
# QDRANT_API_KEY=your-cluster-api-key
